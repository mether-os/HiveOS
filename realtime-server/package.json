{
  "name": "hiveos-realtime-server",
  "version": "1.0.0",
  "description": "Standalone Socket.io server for HiveOS realtime presence and activities",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.7",
